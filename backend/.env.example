APP_NAME=OutcomeIQ API
APP_VERSION=0.1.0
ENVIRONMENT=development
# Optional Docker-compatible alias for ENVIRONMENT:
APP_ENV=
DEBUG=false
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
# PostgreSQL example (replace the placeholder only in backend/.env):
# DATABASE_URL=postgresql+psycopg2://postgres:your_password@localhost:5432/outcomeiq_dev
DATABASE_URL=
REDIS_URL=
JWT_SECRET_KEY=change-this-in-development
# Optional Docker-compatible alias for JWT_SECRET_KEY:
SECRET_KEY=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
LOG_LEVEL=INFO
BILLING_PROVIDER_MODE=test
RAZORPAY_MODE=test
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_STARTER_PLAN_ID=
RAZORPAY_PRO_PLAN_ID=
RAZORPAY_CHECKOUT_ENABLED=true
PAYMENTS_LIVE_ENABLED=false
APP_PUBLIC_URL=
SUPPORT_EMAIL=
ADMIN_EMAILS=admin@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=
MAIL_FROM_NAME=OutcomeIQ
OTP_EXPIRE_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=60
